{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepService": false,
    "restartPolicyType": "ON_FAILURE"
  },
  "services": {
    "api": {
      "source": "/",
      "healthcheckPath": "/health",
      "healthcheckTimeout": 120,
      "startCommand": "python3 -m uvicorn main:app --host 0.0.0.0 --port ${PORT:-8080} --proxy-headers --forwarded-allow-ips='*'"
    },
    "worker": {
      "source": "/",
      "startCommand": "python3 -m celery -A tasks.zerodha_tasks worker --loglevel=info -B"
    }
  }
}